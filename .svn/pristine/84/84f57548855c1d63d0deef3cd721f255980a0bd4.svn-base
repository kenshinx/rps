include build.mk


pkg: prepare
	@export builddir=$(shell pwd)/build; \
	echo $(SVNVERSION); \
	for pkg in $(PKG); do \
		pkg=$$(basename $${pkg} .spec); \
		echo "Building $${pkg}"; \
		paths=$$(rpm -q --specfile --qf "build/RPMS/%{arch}/$${pkg}-${SVNVERSION}-%{release}.%{arch}.rpm " $${pkg}.spec); \
		echo $${paths};\
		rpmbuild --define="_module_name ${PROJ}" --define="_version ${SVNVERSION}" --define="_topdir $${builddir}" -bb $${pkg}.spec && \
			pwd && \
			mkdir -p backup-rpms &&\
			cp $${paths} backup-rpms && \
			cp $${paths} ./ && \
			continue; \
		echo "Build failed for $${pkg}, abort."; \
		break; \
	done

# Make rpm building base and source tarball
prepare: clean-build clean-rpm build
	echo "Creating source package to build/SOURCES/$(SRC)"
	mkdir -p $(TEMP_DIR)
	@echo $(TEMP_DIR)/$(PROJ)
	rm -f $(TEMP_DIR)/$(PROJ)
	ln -s $(ROOT_DIR) $(TEMP_DIR)/$(PROJ)
	@echo $(ROOT_DIR)
	tar zchf $(TEMP_DIR)/$(SRC) \
		--exclude request_sample \
		--exclude qmodule \
		--exclude "*lib${PROJ}*.tar.gz" \
		--exclude t \
		--exclude .git \
		--exclude .svn\
		--exclude "*.o" \
		--exclude "*.pyo" \
		--exclude "*.pyc" \
		--exclude "*.rpm" \
		--exclude "logs" \
		--exclude "nohup.out" \
		-C $(TEMP_DIR) $(PROJ)
	@pwd
	mkdir -p build/BUILD
	mkdir -p build/RPMS
	mkdir -p build/SRPMS
	mkdir -p build/SPECS
	mkdir -p build/SOURCES
	mv $(TEMP_DIR)/$(SRC) build/SOURCES/

build:
	echo "Execute Go build" 
	
	@echo Build niss_ex
	cd $(ROOT_DIR) && make single -B && make install


clean-build:
	rm -rf build

clean-rpm:
	rm -rf *rpm

clean: clean-build clean-rpm
	rm -rf *.pyc *.pyo *.o

.PHONY: pkg prepare clean clean-build clean-rpm

